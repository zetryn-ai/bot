# zetryn-bot — environment variables template
#
# Copy this file to `.env` and fill in the values. Do NOT commit `.env`.
# Nothing is strictly required: `python -m zetryn_bot` runs with an empty
# file (the zero-arg Dexscreener/GeckoTerminal/Raydium scanners always run).
# Sources and enrichers whose keys are missing are skipped at runtime.

# ─── Transport ─────────────────────────────────────────────────────────────
# NOT used by the M3 runtime (single-process, in-memory). Comes back when a
# Redis-backed decision sink lands (M7/M9). Safe to leave at the default.
REDIS_URL=redis://localhost:6379/0

# ─── LLM analyst (OPTIONAL — resolved by the zetryn-trading framework) ───────
# The runtime auto-detects a provider from the first key present below and runs
# the full LLM analyst path; with none set it runs rule-only (hard gates only).
# NOTE: these keys are consumed by the framework (zetryn-trading), not by the
# bot's Settings — the bot never reads their value. They live here only because
# .env is a shared file. Groq has the easiest free tier.
GROQ_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# Optional: override the chosen provider's default model.
# LLM_MODEL=

# ─── Solana RPC ────────────────────────────────────────────────────────────
# Used by helius / pumpfun / raydium scanners. Helius is recommended primary
# (sign up free at https://helius.dev — append `?api-key=<key>` to the URL).
SOLANA_RPC_URL=
SOLANA_RPC_FALLBACK_URL=

# ─── Scanner API keys ──────────────────────────────────────────────────────
# Multiple keys = comma-separated, rotated via APIKeyPool (RPM/RPD aware).

# Helius (free tier available, https://helius.dev)
# Used by: helius.py (DAS API, RPC), and any scanner that hits Solana RPC.
HELIUS_API_KEYS=

# BirdEye (free tier at https://birdeye.so/developers)
# Used by: birdeye.py (trending, new listings).
BIRDEYE_API_KEYS=

# GMGN (https://gmgn.ai — requires API key purchase or partner key)
# Used by: gmgn_openapi.py (safety + smart-wallet signals).
GMGN_API_KEY=

# PumpPortal API key (https://pumpportal.fun)
# Used by: pumpfun.py (Pump.fun WebSocket stream — new token + migration).
PUMPPORTAL_API_KEY=

# ─── Telegram scanner (telethon) ───────────────────────────────────────────
# Get from https://my.telegram.org/apps. The .session file is written on
# first run after interactive login; keep it out of git (gitignored).
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=telegram_session
# JSON list of channels to monitor (scanner idle if empty). Example:
# TELEGRAM_CHANNELS=[{"username": "@alphagroup", "category": "alpha", "display_name": "Alpha"}]
TELEGRAM_CHANNELS=

# ─── Twitter scanner (twitter_login) ───────────────────────────────────────
# twitter_login persists cookies after a one-time login. The directory is
# gitignored — do NOT commit cookies.
TWITTER_COOKIES_PATH=twitter_cookies

# ─── Runtime orchestration (M3) ────────────────────────────────────────────
# CSV of scanner .name's to keep enabled (empty = auto-enable all whose keys
# are present). e.g. SCANNERS_ENABLED=dexscreener.boost,raydium.new_pools
SCANNERS_ENABLED=
WORKERS=4              # pipeline worker pool size (caps LLM concurrency)
QUEUE_SIZE=1000        # candidate queue maxsize (backpressure bound)
DEDUP_TTL_S=60         # window (seconds) for collapsing duplicate mints

# ─── Decision gate thresholds ──────────────────────────────────────────────
# The three hard gates (safety / intel / market) check these BEFORE the LLM
# analyst runs. Defaults match the framework. To exercise the AI path (let more
# candidates reach the LLM), loosen them — e.g. set the first four to 0 and the
# concentration/bundler limits wide open:
#   GATE_MIN_LIQUIDITY_USD=0
#   GATE_MIN_VOLUME_1H=0
#   GATE_MIN_HOLDERS=0
#   GATE_MIN_GMGN_SAFETY_SCORE=0
#   GATE_MAX_TOP10_PCT=1.0
#   GATE_MAX_BUNDLER_WALLETS=1000000
GATE_MIN_LIQUIDITY_USD=5000
GATE_MIN_VOLUME_1H=10000
GATE_MAX_TOP10_PCT=0.5
GATE_MIN_HOLDERS=50
GATE_MAX_BUNDLER_WALLETS=3
GATE_MIN_GMGN_SAFETY_SCORE=40

# ─── Execution layer (M4 — paper trading) ──────────────────────────────────
# Off by default: with EXECUTION_ENABLED=false the runtime is identical to M3
# (decisions logged, no positions). Turn on to paper-trade alerts at real
# Jupiter quote prices (no transactions, no keypair, no funds).
EXECUTION_ENABLED=false
RISK_BASE_SIZE_SOL=0.1        # base position size; actual = base x confidence
RISK_MIN_CONFIDENCE=0.6       # only alerts at/above this confidence buy
RISK_MAX_POSITIONS=5          # max concurrent open positions
RISK_BUY_ACTIONS=alert        # CSV of actions that buy; use "alert,watch" to also paper-trade the watchlist
RISK_DAILY_LOSS_LIMIT_SOL=1.0 # circuit breaker: stop buying past this daily loss
EXIT_TP_PCT=0.30              # take profit at +30%
EXIT_SL_PCT=0.15             # stop loss at -15%
EXIT_MAX_HOLD_S=1800          # force-close after 30 min
EXEC_POLL_INTERVAL_S=5.0      # position monitor poll cadence
# JUPITER_QUOTE_URL=https://lite-api.jup.ag/swap/v1/quote  # override if needed
# JUPITER_SWAP_URL=https://lite-api.jup.ag/swap/v1/swap    # override if needed

# ─── Wallet + live execution (M5) ───────────────────────────────────────────
# Live execution requires EXECUTION_ENABLED=true AND EXECUTION_MODE=live AND a
# valid wallet keyfile — any missing piece falls back to paper (logged loudly),
# never crashes, never silently goes live. Create the keyfile once with:
#   python scripts/wallet_init.py
# It writes WALLET_KEYFILE_PATH (encrypted; gitignored) and prints the pubkey.
# Fund that address before ever setting EXECUTION_MODE=live.
# paper | live — must be explicitly "live" for real funds
EXECUTION_MODE=paper
WALLET_KEYFILE_PATH=wallet.enc
# WALLET_PASSPHRASE — set after wallet_init.py; keep separate from wallet.enc.
# NOTE: no inline comments on blank-value lines — dotenv would treat the comment
# as the value. Put comments on their own line above.
WALLET_PASSPHRASE=
WALLET_MIN_SOL_RESERVE=0.05
WALLET_MAX_TRADE_SOL=0.5
LIVE_SLIPPAGE_BPS=200
# LIVE_PRIORITY_FEE_LAMPORTS — leave empty for Jupiter auto priority fee
LIVE_PRIORITY_FEE_LAMPORTS=
# SOLANA_RPC_URL above must be a full RPC endpoint for live mode to work
# (e.g. https://mainnet.helius-rpc.com/?api-key=<key>) — a bare API key/UUID
# is not enough.

# ─── Persistence (M6) ───────────────────────────────────────────────────────
# Open positions, closed trades, and the daily circuit breaker persist here so
# a restart doesn't lose them. If the DB is unreachable at startup the runtime
# falls back to in-memory state (logged), never crashes — so this is optional.
# Create the role + DB once:
#   sudo -u postgres psql -c "CREATE ROLE zetryn LOGIN PASSWORD 'zetryn';"
#   sudo -u postgres psql -c "CREATE DATABASE zetryn_bot OWNER zetryn;"
# then apply the schema: alembic upgrade head   (or use docker-compose up -d)
DATABASE_URL=postgresql+asyncpg://zetryn:zetryn@localhost:5432/zetryn_bot
# Opt-in: wire the framework's Postgres-backed DecisionLog into the agent,
# activating ReflectiveNode (the analyst learns from recent losses).
ENABLE_DECISION_LOG=false

# ─── Notifications (M7 — Telegram) ──────────────────────────────────────────
# Off by default. When enabled, pushes: trade open/close (with PnL), circuit
# breaker trips, critical errors (DB/wallet/RPC failures), and scanner
# rate-limit / LLM key-rotation warnings (deduplicated per event within
# NOTIFY_DEDUP_WINDOW_S so a repeating failure sends once, not a flood).
# Create a bot via @BotFather to get TELEGRAM_BOT_TOKEN — this is separate
# from TELEGRAM_API_ID/HASH above (that's the telethon scanner's user session).
# Get TELEGRAM_CHAT_ID by messaging your bot once, then GET
# https://api.telegram.org/bot<token>/getUpdates and reading "chat":{"id":...}.
NOTIFY_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_DEDUP_WINDOW_S=900
HEARTBEAT_INTERVAL_S=3600

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Leave empty for the default daily-rotated JSON sink under ./logs/.
LOG_FILE=
